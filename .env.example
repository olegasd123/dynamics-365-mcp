# Option 1: Path to JSON config file (supports multiple environments)
# D365_MCP_CONFIG=~/.dynamics-365-mcp/config.json

# Option 2: Connection string (single environment)
# D365_CONNECTION_STRING=AuthType=ClientSecret;Url=https://org.crm.dynamics.com;ClientId=YOUR_CLIENT_ID;ClientSecret=YOUR_CLIENT_SECRET;TenantId=YOUR_TENANT_ID
# D365_CONNECTION_STRING=AuthType=DeviceCode;Url=https://org.crm.dynamics.com;TenantId=YOUR_TENANT_ID;ClientId=YOUR_CLIENT_ID

# Option 3: Named connection strings as JSON (multiple environments)
# D365_CONNECTION_STRINGS={"environments":[{"name":"dev","connectionString":"AuthType=ClientSecret;Url=https://dev-org.crm.dynamics.com;ClientId=YOUR_CLIENT_ID;ClientSecret=YOUR_CLIENT_SECRET;TenantId=YOUR_TENANT_ID"},{"name":"prod","connectionString":"AuthType=ClientSecret;Url=https://prod-org.crm.dynamics.com;ClientId=YOUR_CLIENT_ID;ClientSecret=YOUR_CLIENT_SECRET;TenantId=YOUR_TENANT_ID"}],"defaultEnvironment":"dev"}
# D365_CONNECTION_STRINGS={"environments":[{"name":"dev","connectionString":"AuthType=DeviceCode;Url=https://dev-org.crm.dynamics.com;TenantId=YOUR_TENANT_ID;ClientId=YOUR_CLIENT_ID"}],"defaultEnvironment":"dev"}

# Optional HTTP mode for service scripts
# MCP_TRANSPORT=http
# MCP_PORT=3003
# MCP_HOST=127.0.0.1
# MCP_PATH=/mcp

# Optional request logs
# Writes one log file per MCP tool call into ~/.dynamics-365-mcp/logs/DDMMYYYY/HHMMSSmmm-tool-...txt
# D365_MCP_LOG_ENABLED=false
# D365_MCP_LOG_DIR=~/.dynamics-365-mcp/logs
# D365_MCP_LOG_MAX_BODY_CHARS=0
