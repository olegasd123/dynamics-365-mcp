          "targetEnvironment": "test"
        }
      }
    ],
    "compare_environment_matrix": [
      {
        "name": "plugin matrix",
        "arguments": {
          "baselineEnvironment": "dev",
          "targetEnvironments": ["test"],
          "componentType": "plugins",
          "assemblyName": "Contoso.Plugins",
          "maxRows": 10
        }
      }
    ],
    "compare_forms": [
      {
        "name": "account main form",
