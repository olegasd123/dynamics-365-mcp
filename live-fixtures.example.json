          "maxDependencies": 20
        }
      }
    ],
    "analyze_update_triggers": [
      {
        "name": "account name",
        "arguments": {
          "environment": "dev",
          "table": "account",
          "changedAttributes": ["name"]
        }
      }
    ],
    "compare_custom_apis": [
