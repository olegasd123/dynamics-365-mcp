    "analyze_create_triggers": [
      {
        "name": "account name",
        "enabled": false,
        "skipReason": "This test is currently disabled.",
        "arguments": {
          "environment": "dev",
          "table": "account",
          "providedAttributes": ["name"]
        }
      }
    ],
    "analyze_impact": [
      {
        "name": "account name column",
        "arguments": {
          "environment": "dev",
          "componentType": "column",
          "table": "account",
