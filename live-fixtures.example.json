        "arguments": {
          "environment": "dev",
          "table": "account",
          "providedAttributes": ["name"]
        }
      }
    ],
    "analyze_impact": [
      {
        "name": "account name column",
        "arguments": {
          "environment": "dev",
          "componentType": "column",
