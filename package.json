{
  "name": "dynamics-365-mcp",
  "version": "0.1.0",
  "description": "MCP server for Microsoft Dynamics 365 CRM metadata queries and cross-environment comparison",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dynamics-365-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:contracts": "vitest run src/tools/__tests__/tool-contracts.integration.test.ts",
    "test:transport": "vitest run src/__tests__/runtime-transports.test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "dynamics-365",
    "crm",
    "dataverse"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
